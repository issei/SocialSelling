{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(gh project *)",
      "Bash(gh pr create *)",
      "Bash(gh pr merge *)",
      "Bash(gh pr view *)",
      "Bash(gh pr list *)",
      "Bash(gh pr checks *)",
      "Bash(gh pr diff *)",
      "Bash(gh pr edit *)",
      "Bash(gh pr update-branch *)",
      "Bash(gh issue view *)",
      "Bash(gh run list *)",
      "Bash(gh run view *)",
      "Bash(gh run watch *)",
      "Bash(gh api *)",
      "Bash(gh auth *)",
      "Bash(gh repo view *)",
      "Bash(gh repo *)",
      "Bash(git status*)",
      "Bash(git log *)",
      "Bash(git diff *)",
      "Bash(git show *)",
      "Bash(git ls-files *)",
      "Bash(git ls-remote *)",
      "Bash(git worktree list)",
      "Bash(git checkout *)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git merge *)",
      "Bash(git push *)",
      "Bash(git pull *)",
      "Bash(git branch *)",
      "Bash(git fetch *)",
      "Bash(git tag *)",
      "Bash(./scripts/gate.ps1)",
      "Bash(./scripts/gate.ps1 *)",
      "Bash(./scripts/gate.sh)",
      "Bash(powershell -ExecutionPolicy Bypass -File scripts/gate.ps1*)",
      "Bash(pwsh scripts/new_card.ps1 *)",
      "Bash(py -m pytest *)",
      "Bash(py -m ruff *)",
      "Bash(py -m mypy *)",
      "Bash(.venv/Scripts/python.exe -m pytest *)",
      "Bash(.venv/Scripts/python.exe -m ruff *)",
      "Bash(.venv/Scripts/python.exe -m mypy *)"
    ],
    "deny": [
      "Bash(git push --force *)",
      "Bash(git push -f *)",
      "Bash(git push --force-with-lease *)",
      "Bash(git reset --hard *)",
      "Bash(gh api -X DELETE *)",
      "Bash(gh api --method DELETE *)",
      "Bash(gh repo delete *)"
    ]
  }
}
